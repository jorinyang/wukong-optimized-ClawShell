#!/bin/bash
#===============================================================================
# ClawShell v1.0 - 主入口CLI
#===============================================================================
# 用法:
#   clawshell <command> [options]
#
# 命令:
#   status     - 显示系统状态
#   health     - 健康检查
#   events     - 事件总线状态
#   market     - 任务市场状态
#   swarm      - Swarm集群状态
#   sync       - Hermes同步
#   version    - 显示版本
#===============================================================================

set -e

# ClawShell路径配置
# 优先使用环境变量，否则指向ClawShell安装目录
if [ -z "$CLAWSHELL_ROOT" ]; then
    if [ -d "$HOME/.ClawShell" ]; then
        CLAWSHELL_ROOT="$HOME/.ClawShell"
    elif [ -d "/Users/$USER/.real/.ClawShell" ]; then
        CLAWSHELL_ROOT="/Users/$USER/.real/.ClawShell"
    else
        CLAWSHELL_ROOT="$HOME/.ClawShell"
    fi
fi
VERSION="1.0.0"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_ok()   { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_err()  { echo -e "${RED}[ERROR]${NC} $1"; }

show_version() {
    echo "ClawShell v${VERSION}"
    echo "  Root: ${CLAWSHELL_ROOT}"
    cat "${CLAWSHELL_ROOT}/MANIFEST.json" 2>/dev/null | head -5 || true
}

show_status() {
    log_info "ClawShell v${VERSION} 系统状态"
    echo ""
    
    # 检查核心目录
    log_info "核心目录:"
    for dir in lib/core/eventbus lib/core/genome lib/layer1 lib/layer2 lib/layer3 lib/layer4 lib/bridge; do
        if [ -d "${CLAWSHELL_ROOT}/${dir}" ]; then
            count=$(find "${CLAWSHELL_ROOT}/${dir}" -maxdepth 1 -name "*.py" -o -name "*.sh" 2>/dev/null | wc -l | tr -d ' ')
            log_ok "  ${dir}/ (${count} items)"
        else
            log_err "  ${dir}/ (不存在)"
        fi
    done
}

cmd_health() {
    log_info "健康检查..."
    python3 -c "
import sys
sys.path.insert(0, '${CLAWSHELL_ROOT}')
try:
    from lib.layer1 import HealthMonitor
    print('Layer1 (自感知): OK')
except Exception as e:
    print(f'Layer1 (自感知): FAIL - {e}')

try:
    from lib.layer2 import SelfHealing, Discovery
    print('Layer2 (自适应): OK')
except Exception as e:
    print(f'Layer2 (自适应): FAIL - {e}')

try:
    from lib.layer3 import DAG, TaskMarket
    print('Layer3 (自组织): OK')
except Exception as e:
    print(f'Layer3 (自组织): FAIL - {e}')

try:
    from lib.layer4 import SwarmDiscovery
    print('Layer4 (集群): OK')
except Exception as e:
    print(f'Layer4 (集群): FAIL - {e}')
" 2>&1
}

cmd_events() {
    log_info "EventBus 状态..."
    python3 -c "
import sys
sys.path.insert(0, '${CLAWSHELL_ROOT}')
try:
    from lib.core.eventbus import EventBus
    eb = EventBus()
    print(f'EventBus: OK (subscribers={len(eb.subscribers)})')
except Exception as e:
    print(f'EventBus: FAIL - {e}')
" 2>&1
}

cmd_market() {
    log_info "TaskMarket 状态..."
    python3 -c "
import sys
sys.path.insert(0, '${CLAWSHELL_ROOT}')
try:
    from lib.layer3 import TaskMarket
    print('TaskMarket: OK')
except Exception as e:
    print(f'TaskMarket: FAIL - {e}')
" 2>&1
}

cmd_swarm() {
    log_info "Swarm 集群状态..."
    python3 -c "
import sys
sys.path.insert(0, '${CLAWSHELL_ROOT}')
try:
    from lib.layer4 import SwarmDiscovery
    print('SwarmDiscovery: OK')
except Exception as e:
    print(f'SwarmDiscovery: FAIL - {e}')
" 2>&1
}

cmd_sync() {
    log_info "Hermes 同步..."
    bash "${CLAWSHELL_ROOT}/bin/clawsync" "$@"
}

# 主入口
COMMAND="${1:-status}"
shift 2>/dev/null || true

case "${COMMAND}" in
    version|v)      show_version ;;
    status|s)       show_status ;;
    health|h)       cmd_health ;;
    events|e)       cmd_events ;;
    market|m)       cmd_market ;;
    swarm|sw)       cmd_swarm ;;
    sync)           cmd_sync ;;
    help|--help|-h) show_version; echo ""; cat << EOF
用法: clawshell <command>

命令:
  version, v    显示版本信息
  status, s     显示系统状态
  health, h     健康检查
  events, e     EventBus状态
  market, m     TaskMarket状态
  swarm, sw     Swarm集群状态
  sync          Hermes同步

示例:
  clawshell status
  clawshell health
  clawshell sync
EOF
    ;;
    *)              log_err "未知命令: ${COMMAND}"; exit 1 ;;
esac
