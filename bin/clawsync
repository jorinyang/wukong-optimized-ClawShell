#!/bin/bash
#===============================================================================
# Clawsync - Hermes同步脚本
#===============================================================================
# 用于: 从Hermes同步洞察到ClawShell知识库
#===============================================================================

set -e

CLAWSHELL_ROOT="${CLAWSHELL_ROOT:-$HOME/.openclaw/clawshell_v1}"
HERMES_BRIDGE="${HOME}/.openclaw/workspace/shared/hermes_bridge"

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_ok()   { echo -e "${GREEN}[OK]${NC} $1"; }

log_info "Clawsync - Hermes同步"
log_info "Hermes Bridge: ${HERMES_BRIDGE}"

# 运行Hermes同步脚本
if [ -f "${HERMES_BRIDGE}/cron_hermes_sync.sh" ]; then
    log_info "执行Hermes同步..."
    bash "${HERMES_BRIDGE}/cron_hermes_sync.sh"
    log_ok "Hermes同步完成"
else
    log_warn "未找到Hermes同步脚本: ${HERMES_BRIDGE}/cron_hermes_sync.sh"
fi

# 运行clawshell内的hermes consumer
if [ -f "${CLAWSHELL_ROOT}/../clawshell/hermes_consumer.py" ]; then
    log_info "处理Hermes洞察..."
    python3 "${CLAWSHELL_ROOT}/../clawshell/hermes_consumer.py" "$@" || true
fi

log_ok "同步完成"
