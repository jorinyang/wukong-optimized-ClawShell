# ClawShell v1.0 配置模板

# 日志配置
log:
  level: INFO
  file: ~/.openclaw/logs/clawshell.log
  max_size: 100MB
  backup_count: 5

# EventBus配置
eventbus:
  queue_size: 1000
  dead_letter_threshold: 3
  enable_metrics: true
  enable_tracing: false

# TaskMarket配置
task_market:
  max_concurrent_tasks: 10
  task_timeout: 300
  enable_dag: true

# Swarm配置
swarm:
  discovery_interval: 60
  health_check_interval: 30
  trust_threshold: 0.7

# Genome配置
genome:
  cache_size: 1000
  index_update_interval: 3600
  quality_threshold: 0.6

# Hermes Bridge配置
hermes:
  sync_interval: 300
  consumer_enabled: true
  scenario_dir: ~/.openclaw/workspace/shared/hermes_bridge

# N8N配置
n8n:
  webhook_url: http://localhost:5678/webhook
  api_key: your_n8n_api_key
  enable_auto_trigger: true
