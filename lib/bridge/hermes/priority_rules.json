{
  "version": "0.8.3",
  "description": "Hermes Bridge 优先级规则配置",
  "updated": "2026-04-29",
  
  "task_type_keywords": {
    "execution": ["execute", "run", "task", "job", "perform", "do"],
    "analysis": ["analyze", "research", "investigate", "study", "examine", "review"],
    "creation": ["create", "write", "generate", "design", "produce", "build"],
    "decision": ["decide", "choose", "select", "evaluate", "judge", "assess"],
    "maintenance": ["maintain", "fix", "repair", "update", "patch", "improve"]
  },
  
  "priority_rules": {
    "explicit_priority": {
      "P0": {
        "description": "系统故障/数据损失",
        "response_mode": "instant",
        "response_time": "<5分钟"
      },
      "P1": {
        "description": "重要任务/客户相关",
        "response_mode": "fast",
        "response_time": "<2小时"
      },
      "P2": {
        "description": "常规任务",
        "response_mode": "standard",
        "response_time": "<24小时"
      },
      "P3": {
        "description": "后台任务/探索",
        "response_mode": "batch",
        "response_time": "<7天"
      }
    },
    
    "environment_modifiers": {
      "production": {
        "P0": "P0",
        "P1": "P0",
        "P2": "P1",
        "P3": "P2",
        "description": "生产环境优先级提升"
      },
      "staging": {
        "P0": "P1",
        "P1": "P1",
        "P2": "P2",
        "P3": "P2",
        "description": "预发环境保持原级或提升"
      },
      "development": {
        "P0": "P2",
        "P1": "P2",
        "P2": "P3",
        "P3": "P3",
        "description": "开发环境优先级降低"
      }
    }
  },
  
  "match_matrix": {
    "P0_production": "instant",
    "P0_staging": "instant",
    "P0_development": "fast",
    "P1_production": "fast",
    "P1_staging": "fast",
    "P1_development": "fast",
    "P2_production": "standard",
    "P2_staging": "standard",
    "P2_development": "batch",
    "P3_production": "standard",
    "P3_staging": "batch",
    "P3_development": "batch"
  },
  
  "task_type_modifiers": {
    "decision": {
      "standard": "fast",
      "batch": "standard",
      "description": "决策类任务优先级提升"
    },
    "analysis": {
      "fast": "standard",
      "standard": "batch",
      "description": "分析类任务可接受批量处理"
    },
    "creation": {
      "batch": "standard",
      "description": "创作类任务避免批量"
    }
  },
  
  "error_severity_mapping": {
    "critical": "instant",
    "error": "fast",
    "warning": "standard",
    "info": "batch"
  }
}
